# ---- Frontend (Vite): dataset source ----
# Uncomment to force loading from S3 only (no fallback to local). Requires S3 server running: npm run server
# VITE_DATASET_URL=/api/dataset

# ---- Backend (S3 server): AWS credentials ----
# Copy this file to .env in this folder (ecoroute_2/.env) and fill in real values.
# Use KEY=value only — no "export", no quotes around values.

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Required for temporary credentials (e.g. from AWS SSO or assumed role)
# AWS_SESSION_TOKEN=your_session_token

# Optional; default is us-east-1
# AWS_REGION=us-east-1

# Optional overrides for S3 path
# S3_BUCKET=internal-testing-1
# S3_INPUT_PREFIX=input/
