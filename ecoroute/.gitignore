# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# Yarn Berry
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build Output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
out/
build/
*.local

# ── Vite ─────────────────────────────────────────────────────────────────────
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Environment & Secrets ─────────────────────────────────────────────────────
# Keep .env.example committed; ignore everything else
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local

# ── AWS ───────────────────────────────────────────────────────────────────────
.aws/
.s3-cache/
*.s3-cache

# ── Docker ────────────────────────────────────────────────────────────────────
# Ignore local override compose files but keep the main ones
docker-compose.override.yml

# ── Dataset / Large Data Files ────────────────────────────────────────────────
dataset/
*.csv
*.geojson
*.parquet

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Debug Logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# JetBrains IDEs
.idea/
*.iml

# VS Code (keep shared settings; ignore personal overrides)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Vim / Emacs swap files
*.swp
*.swo
*~

# ── Certificates & Keys ───────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ── Misc Scratch / Temp Files ─────────────────────────────────────────────────
*.tmp
*.temp
scratch/

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel
.netlify

# ── SonarQube ─────────────────────────────────────────────────────────────────
.scannerwork/
